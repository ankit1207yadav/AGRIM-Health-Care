.pybuilder/
target/

# Jupyter Notebook
.ipynb_checkpoints

# IPython
profile_default/
ipython_config.py

# pyenv
#   For a library or app, you might want to share this in the commit to
#   specify the python version, but usually it's local settings.
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, if you're executing a library and not an application, you may want to ignore it.
#   Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock can be submitted or ignored, depending on the usage.
#   poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock can be submitted or ignored, depending on the usage.
#   pdm.lock

# PEP 582; project local packages directory (used by pdm)
__pypackages__/

# Celery stuff
celerybeat-schedule
celerybeat.pid

# SageMath parsed files
*.sage.py

